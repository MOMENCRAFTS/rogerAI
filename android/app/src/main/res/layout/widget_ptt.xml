<?xml version="1.0" encoding="utf-8"?>
<!-- RogerAI PTT Quick-Launch Widget Layout (2×2)
     Amber command-gold walkie-talkie aesthetic -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_amber"
    android:padding="8dp"
    android:id="@+id/widget_ptt_root">

    <!-- R brand badge — top left -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:text="R"
        android:textColor="#d4a044"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:layout_marginStart="4dp"
        android:layout_marginTop="2dp" />

    <!-- Center content -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:gravity="center_horizontal">

        <!-- Outer glow ring -->
        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center">

            <!-- Glow ring -->
            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/widget_ptt_glow"
                android:layout_gravity="center" />

            <!-- Inner button circle -->
            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/widget_ptt_circle"
                android:layout_gravity="center" />

            <!-- Mic icon -->
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/widget_mic_icon"
                android:layout_gravity="center" />
        </FrameLayout>

        <!-- TAP TO TALK label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TAP TO TALK"
            android:textColor="#d4a044"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.22"
            android:textAllCaps="true"
            android:layout_marginTop="6dp" />

        <!-- Status subtitle -->
        <TextView
            android:id="@+id/ptt_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Standing by. Over."
            android:textColor="#6b6a5e"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>
</FrameLayout>
